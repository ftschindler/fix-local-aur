[Unit]
Description=Watch local AUR repo dir and trigger DB rebuild (user)

[Path]
PathExistsGlob=/var/lib/repo/aur/*.pkg.*
# Do not watch for arbitrary directory changes here. Writing or updating
# the repo DB (aur.db / aur.db.tar.gz) modifies the directory and would
# retrigger the unit, causing a self-restart loop. Only trigger when
# package files appear or disappear.
# PathChanged=/var/lib/repo/aur
Unit=fix-aurdb.service

[Install]
WantedBy=default.target
